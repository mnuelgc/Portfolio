---
import "../styles/global.css";

interface Props {
	title: string;
	description?: string;
	image?: string;
}

const locale = Astro.currentLocale ?? "en";
const descriptions = {
	en: "Mobile software engineer building immersive AR/VR and native experiences.",
	es: "Ingeniero de software móvil especializado en experiencias AR/VR y apps nativas.",
};

const { title, description, image } = Astro.props as Props;
const metaDescription = description ?? descriptions[locale as "en" | "es"] ?? descriptions.en;
const ogImage = image ?? "/circularphoto.png";
const canonical = new URL(Astro.request.url);
const localeTag = locale === "es" ? "es_ES" : "en_US";
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={metaDescription} />
		<meta name="color-scheme" content="dark light" />
		<meta name="theme-color" content="#080b12" />
		<link rel="canonical" href={canonical.href} />
		<link rel="icon" type="image/svg+xml" href="/circularphoto.png" />
		<meta name="generator" content={Astro.generator} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={metaDescription} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical.href} />
		<meta property="og:locale" content={localeTag} />
		<meta property="og:image" content={ogImage} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={metaDescription} />
		<meta name="twitter:image" content={ogImage} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
		/>
		<title>{title}</title>
	</head>
	<body class="bg-brand-coal font-sans">
		<div class="min-h-screen">
			<slot />
		</div>
	</body>
</html>
