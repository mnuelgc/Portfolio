---
import ProjectPage from "../../../components/pages/ProjectPage.astro";
import type { Locale } from "../../../i18n/ui";
import { getProjectStaticPaths } from "../../../lib/projectPaths";

export const getStaticPaths = getProjectStaticPaths;

const locale = "es" satisfies Locale;
const { id } = Astro.params;

if (!id) {
	throw new Error("Missing project id");
}
---

<ProjectPage locale={locale} id={id} />
