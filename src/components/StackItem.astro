---
interface Props {
	name: string;
	icon: string;
	showLabel?: boolean;
}

const { name, icon, showLabel = true } = Astro.props;
---

<div class="stack-chip">
	<img
		src={icon}
		alt={`${name} logo`}
		loading="lazy"
		class="stack-chip__icon"
	/>
 	{showLabel && <p class="stack-chip__label">{name}</p>}
</div>

<style>
	.stack-chip {
		position: relative;
		width: 150px;
		height: 150px;
		border-radius: 1.75rem;
		background: linear-gradient(160deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02));
		border: 1px solid rgba(255, 255, 255, 0.12);
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.6rem;
		text-align: center;
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.45);
		overflow: hidden;
	}

	.stack-chip::after {
		content: "";
		position: absolute;
		inset: 30%;
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 1.2rem;
		pointer-events: none;
	}

	.stack-chip__icon {
		width: 56px;
		height: 56px;
		object-fit: contain;
		filter: drop-shadow(0 10px 15px rgba(0, 0, 0, 0.35));
	}

	.stack-chip__label {
		font-size: 0.85rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.85);
	}
</style>
